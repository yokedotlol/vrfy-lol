# vrfy.lol environment variables
# Copy to .dev.vars for local development: cp .env.example .dev.vars

# Required — HMAC key for pseudonymized email-level cache keys
# Generate: openssl rand -hex 32
CACHE_SECRET=

# Required — HMAC key for PoW challenge generation (IP-bound)
# Generate: openssl rand -hex 32
POW_SECRET=

# Optional — admin key for diagnostic endpoints
# ADMIN_KEY=

# Optional — bearer token for Fly probe auth (Phase 2 SMTP checks)
# FLY_AUTH_SECRET=
